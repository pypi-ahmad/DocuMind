# ── DocuMind Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are prefixed with DOCUMIND_ for pydantic-settings,
# but bare names (e.g. OPENAI_API_KEY) are also accepted via aliases.

# ── Cloud Provider API Keys (leave blank to skip) ──────────────────
DOCUMIND_OPENAI_API_KEY=
DOCUMIND_GEMINI_API_KEY=
DOCUMIND_ANTHROPIC_API_KEY=

# ── Ollama (local LLM / OCR) ──────────────────────────────────────
DOCUMIND_OLLAMA_BASE_URL=http://localhost:11434

# ── Application ───────────────────────────────────────────────────
DOCUMIND_APP_ENV=dev
DOCUMIND_LOG_LEVEL=INFO
DOCUMIND_DEBUG=false
DOCUMIND_LLM_DEFAULT_MAX_OUTPUT_TOKENS=1024

# ── Vector Store Backend ──────────────────────────────────────────
# "memory" (default, in-process) or "milvus" (persistent)
DOCUMIND_VECTOR_STORE_BACKEND=memory
DOCUMIND_MILVUS_URI=http://localhost:19530
DOCUMIND_MILVUS_COLLECTION_NAME=documind_chunks
DOCUMIND_MILVUS_TOKEN=
DOCUMIND_MILVUS_VECTOR_DIM=768

# ── Job Queue Backend ────────────────────────────────────────────
# "memory" (default, in-process) or "redis" (persistent, multi-node)
DOCUMIND_JOB_QUEUE_BACKEND=memory
DOCUMIND_REDIS_URL=redis://localhost:6379/0

# ── Authentication ───────────────────────────────────────────────
# Set auth_enabled=true to require JWT tokens on all non-public routes
DOCUMIND_AUTH_ENABLED=false
DOCUMIND_AUTH_SECRET_KEY=change-me-in-production
DOCUMIND_AUTH_ALGORITHM=HS256
DOCUMIND_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
DOCUMIND_AUTH_ADMIN_USERNAME=admin
DOCUMIND_AUTH_ADMIN_PASSWORD=admin
